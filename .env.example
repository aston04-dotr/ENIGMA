# Скопируйте в .env и подставьте значения из Supabase → Project Settings → API
# Self-hosted (VPS): обычно http://IP:8000 + anon из .env сервера; в app.json для Android включён usesCleartextTraffic для http.
# После выполнения schema.sql + migrations в SQL Editor перезапустите Metro (npx expo start -c)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Надёжнее для Auth: legacy «anon» JWT (eyJ…), если publishable-ключ даёт ошибки
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Опционально (только разработка): если Anonymous в GoTrue не срабатывает — тестовый email/пароль
# Создайте пользователя в Authentication → Users, провайдер Email, для простоты отключите Confirm email
# EXPO_PUBLIC_DEV_LOGIN_EMAIL=dev@test.local
# EXPO_PUBLIC_DEV_LOGIN_PASSWORD=ваш_пароль

# ─── Email при новом сообщении в чате (Supabase Edge Function, не в Expo .env) ─
# Выполните supabase/migrations/009_email_notifications.sql
# Задеплойте: supabase functions deploy notify-new-message
# Secrets (Dashboard → Edge Functions): RESEND_API_KEY, RESEND_FROM (опц.),
# PUBLIC_APP_URL (URL приложения для кнопки «Открыть чат»), CHAT_NOTIFY_SECRET (опц.)
# Database → Webhooks: INSERT public.messages → вызов notify-new-message (см. комментарий в миграции)
