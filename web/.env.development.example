# Development (local)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Keep empty in local dev to use same-origin Next API routes (/api/*)
NEXT_PUBLIC_API_BASE_URL=

# Performance tuning (dev defaults)
NEXT_PUBLIC_LISTINGS_PAGE_SIZE=20
NEXT_PUBLIC_MAX_LISTING_PHOTOS=8

# Server-only
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# RESEND_API_KEY=your_resend_api_key
# RESEND_FROM=Enigma <no-reply@enigma-app.online>
