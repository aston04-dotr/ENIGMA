# Обязательны. URL — только https://…supabase.co из Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
NEXT_PUBLIC_SITE_URL=https://enigma-app.online

# Централизованный API base URL для frontend запросов.
# В production: https://api.enigma-app.online
# В dev можно оставить пустым (используются относительные /api/* пути).
NEXT_PUBLIC_API_BASE_URL=https://api.enigma-app.online

# Performance tuning (Supabase Pro/Large)
# Лимит ленты на страницу: допустимо 10..200
NEXT_PUBLIC_LISTINGS_PAGE_SIZE=40
# Лимит фото на объявление в web UI: допустимо 1..30
NEXT_PUBLIC_MAX_LISTING_PHOTOS=12

# Только сервер (удаление аккаунта: auth.admin.deleteUser). Не публикуй в клиенте.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PWA: в production включи service worker (офлайн-оболочка, кэш статики)
NEXT_PUBLIC_ENABLE_SW=true
# Email поддержки для тикетов/проблем оплаты (fallback в коде: gt500@internet.ru)
# NEXT_PUBLIC_SUPPORT_EMAIL=gt500@internet.ru
# Только отладка: полный сброс SW + Cache Storage (иначе не включай — ломает установку PWA)
# NEXT_PUBLIC_AGGRESSIVE_SW_CLEAR=true

# Диагностика auth/realtime/chat (console groups + window.ENIGMA_DEBUG_COUNTERS).
# Локально можно задать явно. На Vercel Production включается по умолчанию в next.config (TEMP);
# чтобы выключить на проде: NEXT_PUBLIC_ENIGMA_DIAG=0 в панели хостинга.
# NEXT_PUBLIC_ENIGMA_DIAG=1
# NEXT_PUBLIC_ENIGMA_DIAG=0
