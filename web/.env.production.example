# =============================
# ENIGMA / Production .env
# =============================

# ----- Public app URLs -----
NEXT_PUBLIC_APP_URL=https://enigma-app.online
NEXT_PUBLIC_SITE_URL=https://enigma-app.online
NEXT_PUBLIC_API_BASE_URL=https://enigma-app.online

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ----- YooKassa (LIVE) -----
PAYMENT_MODE=yookassa
NEXT_PUBLIC_PAYMENT_MODE=yookassa
YOOKASSA_SHOP_ID=1346899
YOOKASSA_SECRET_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Notifications / Email -----
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=no-reply@enigma-app.online
NEXT_PUBLIC_SUPPORT_EMAIL=gt500@internet.ru

# ----- Listing expiry cron protection -----
LISTING_EXPIRY_CRON_SECRET=replace_with_long_random_secret

# ----- Optional UI/runtime tuning -----
NEXT_PUBLIC_LISTINGS_PAGE_SIZE=40
NEXT_PUBLIC_MAX_LISTING_PHOTOS=12
NEXT_PUBLIC_LISTING_RENEWAL_PRICE_RUB=0
NEXT_PUBLIC_ENABLE_SW=false
